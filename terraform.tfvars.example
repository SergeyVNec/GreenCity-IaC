# Copy to terraform.tfvars and adjust. All values have sane defaults — you can
# also apply with no tfvars at all.

# region              = "us-east-1"          # everything lives in one region
# ami_id              = ""                    # empty = latest Amazon Linux 2023 auto-selected
# app_instance_type   = "t3.small"           # app EC2 (3 containers need RAM)
# alarm_email         = "you@example.com"     # empty = no CloudWatch email alerts
# discord_webhook     = "https://discord.com/api/webhooks/..."  # empty = no CI notifications
# frontend_api_url    = "https://your-domain"  # empty = use the ALB DNS name

# NOTE: the two m7i-flex.large observability/control-plane nodes and t3.small
# agents are free-tier eligible in a new-style AWS Free Plan account. On a normal
# paid account this stack is ~$260/mo on-demand.
