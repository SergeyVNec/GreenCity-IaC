# Copy to "setup-cluster.env" and fill in. Loaded automatically by setup-cluster.ps1.
# NEVER put real keys in this .example file — it is committed to git.
# These are the only values that cannot be recreated from code; everything else
# (passwords, tokens, gates, indexes) the script generates or configures itself.

GROQ_API_KEY=gsk_...            # console.groq.com  (Whisper STT for the voice agent)
ELEVENLABS_API_KEY=sk_...       # elevenlabs.io     (TTS for the voice agent)
OPENROUTER_API_KEY=sk-or-...    # openrouter.ai     (LLM for ChatOps)
DATADOG_API_KEY=...             # app.datadoghq.eu  (Datadog agents)
