#!/bin/bash
set -euxo pipefail

dnf install -y unzip
if ! command -v aws >/dev/null 2>&1; then
  curl -sL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip
  unzip -q /tmp/awscliv2.zip -d /tmp && /tmp/aws/install
fi

mkdir -p /etc/rancher/k3s
PASS=$(aws ecr get-login-password --region ${region})
cat >/etc/rancher/k3s/registries.yaml <<REG
configs:
  "${ecr_registry}":
    auth:
      username: AWS
      password: $PASS
REG

# ECR tokens expire ~12h — auto-refresh registries.yaml hourly and reload the agent.
cat >/usr/local/bin/refresh-ecr.sh <<'EOF'
#!/bin/bash
set -e
PASS=$(aws ecr get-login-password --region ${region})
printf 'configs:\n  "%s":\n    auth:\n      username: AWS\n      password: %s\n' "${ecr_registry}" "$PASS" > /etc/rancher/k3s/registries.yaml
systemctl restart k3s-agent
EOF
chmod +x /usr/local/bin/refresh-ecr.sh
cat >/etc/systemd/system/refresh-ecr.service <<'EOF'
[Unit]
Description=Refresh ECR credentials for k3s-agent
[Service]
Type=oneshot
ExecStart=/usr/local/bin/refresh-ecr.sh
EOF
cat >/etc/systemd/system/refresh-ecr.timer <<'EOF'
[Unit]
Description=Refresh ECR credentials every 6h (token lives ~12h)
[Timer]
OnBootSec=10min
OnUnitActiveSec=6h
Persistent=true
[Install]
WantedBy=timers.target
EOF
systemctl daemon-reload
systemctl enable --now refresh-ecr.timer

# Join the server (private IP, same subnet). node_args adds labels/taints for dedicated nodes.
curl -sfL https://get.k3s.io | K3S_URL="https://${server_private_ip}:6443" K3S_TOKEN="${k3s_token}" sh -s - ${node_args}
