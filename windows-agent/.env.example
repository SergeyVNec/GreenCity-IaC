# Copy this file to ".env" and adjust if needed. The script loads it automatically.
# No API keys required — openWakeWord is offline/open-source and the backend holds all keys.
# Set to your ChatOps endpoint: http://<observability_eip>:30890
# (get the IP from `terraform output observability_eip` after deploy)
GREENCITY_BACKEND=http://YOUR-OBSERVABILITY-EIP:30890
WAKE_MODEL=hey_jarvis
# WAKE_THRESHOLD=0.5
# SILENCE_ENERGY=350
